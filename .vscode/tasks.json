{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: install requirements",
      "type": "shell",
      "command": "Set-Location backend; python -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run dev server",
      "type": "shell",
      "command": "Set-Location backend; uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run tests",
      "type": "shell",
      "command": "Set-Location backend; pytest",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: install dependencies",
      "type": "shell",
      "command": "Set-Location frontend; npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: run dev server",
      "type": "shell",
      "command": "Set-Location frontend; npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "Set-Location frontend; npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
