OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
LLM_PROVIDER=auto

LOCAL_LLM_ENABLED=true
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3:4b
LOCAL_LLM_TIMEOUT_SECONDS=120

DATABASE_URL=postgresql://readonly_user:password@localhost:5432/my_database
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=15000
DB_DEFAULT_ROW_LIMIT=100
DB_MAX_ROW_LIMIT=1000
DB_SCHEMA_MAX_TABLES=80
SQL_ALLOW_WRITE_DEFAULT=false
SQL_ENABLE_EXPLAIN_ANALYZE=false
SQL_SENSITIVE_COLUMN_PATTERNS=password,passwd,secret,token,api_key,private_key,ssn,credit_card,card_number,email,phone
